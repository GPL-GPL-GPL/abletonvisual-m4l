    "boxes": [
      { "box": { "id": "obj-1", "maxclass": "comment", "patching_rect": [20.0, 18.0, 320.0, 20.0], "presentation": 1, "presentation_rect": [10.0, 8.0, 104.0, 18.0], "text": "av lane sender" } },
      { "box": { "id": "obj-2", "maxclass": "comment", "patching_rect": [20.0, 42.0, 500.0, 20.0], "presentation": 1, "presentation_rect": [122.0, 8.0, 968.0, 18.0], "text": "Per-track MSP lane -> send av_hub_ingress -> av-sync-hub device" } },
      { "box": { "id": "obj-3", "maxclass": "newobj", "patching_rect": [1180.0, 40.0, 52.0, 22.0], "text": "plugin~" } },
      { "box": { "id": "obj-4", "maxclass": "newobj", "patching_rect": [1180.0, 82.0, 60.0, 22.0], "text": "plugout~" } },
      { "box": { "id": "obj-5", "maxclass": "newobj", "patching_rect": [640.0, 40.0, 126.0, 22.0], "text": "js av_sync_sender.js" } },
      { "box": { "id": "obj-6", "maxclass": "newobj", "patching_rect": [840.0, 40.0, 142.0, 22.0], "text": "send av_hub_ingress" } },
      { "box": { "id": "obj-7", "maxclass": "newobj", "patching_rect": [20.0, 108.0, 58.0, 22.0], "text": "loadbang" } },
      { "box": { "id": "obj-8", "maxclass": "message", "patching_rect": [20.0, 142.0, 30.0, 22.0], "text": "1" } },
      { "box": { "annotation": "Turns lane transmission on or off. When disabled, this device stops sending lane frames and master transport.", "annotation_name": "Enable", "id": "obj-9", "maxclass": "toggle", "patching_rect": [20.0, 176.0, 24.0, 24.0], "presentation": 1, "presentation_rect": [10.0, 34.0, 20.0, 20.0] } },
      { "box": { "id": "obj-10", "maxclass": "message", "patching_rect": [54.0, 176.0, 64.0, 22.0], "text": "enable $1" } },
      { "box": { "id": "obj-11", "maxclass": "comment", "patching_rect": [126.0, 178.0, 60.0, 20.0], "presentation": 1, "presentation_rect": [34.0, 34.0, 46.0, 18.0], "text": "Enable" } },
      { "box": { "id": "obj-12", "maxclass": "message", "patching_rect": [20.0, 214.0, 30.0, 22.0], "text": "1" } },
      { "box": { "annotation": "Enables verbose device reporting. Debug on sends richer /av/debug messages and mirrors them into the Max console.", "annotation_name": "Debug", "id": "obj-13", "maxclass": "toggle", "patching_rect": [20.0, 248.0, 24.0, 24.0], "presentation": 1, "presentation_rect": [86.0, 34.0, 20.0, 20.0] } },
      { "box": { "id": "obj-14", "maxclass": "message", "patching_rect": [54.0, 248.0, 58.0, 22.0], "text": "debug $1" } },
      { "box": { "id": "obj-15", "maxclass": "comment", "patching_rect": [126.0, 250.0, 54.0, 20.0], "presentation": 1, "presentation_rect": [110.0, 34.0, 44.0, 18.0], "text": "Debug" } },
      { "box": { "id": "obj-16", "maxclass": "message", "patching_rect": [20.0, 286.0, 38.0, 22.0], "text": "33" } },
      { "box": { "annotation": "Sets the sender poll interval in milliseconds. This governs master transport polling and lane registration heartbeat timing.", "annotation_name": "Poll ms", "id": "obj-17", "format": 6, "maxclass": "flonum", "patching_rect": [20.0, 320.0, 60.0, 22.0], "presentation": 1, "presentation_rect": [296.0, 32.0, 56.0, 20.0] } },
      { "box": { "id": "obj-18", "maxclass": "message", "patching_rect": [92.0, 320.0, 70.0, 22.0], "text": "interval $1" } },
      { "box": { "id": "obj-19", "maxclass": "comment", "patching_rect": [172.0, 322.0, 60.0, 20.0], "presentation": 1, "presentation_rect": [244.0, 34.0, 48.0, 18.0], "text": "Poll ms" } },
      { "box": { "id": "obj-21", "maxclass": "newobj", "patching_rect": [236.0, 108.0, 86.0, 22.0], "text": "live.thisdevice" } },
      { "box": { "id": "obj-22", "maxclass": "newobj", "patching_rect": [236.0, 142.0, 55.0, 22.0], "text": "deferlow" } },
      { "box": { "id": "obj-23", "maxclass": "message", "patching_rect": [236.0, 176.0, 38.0, 22.0], "text": "ready" } },
      { "box": { "annotation": "Publishes a structured diagnostics snapshot to AbletonVisual and updates the local status line with the current counters.", "annotation_name": "Diagnostics", "id": "obj-24", "maxclass": "message", "patching_rect": [20.0, 360.0, 126.0, 22.0], "presentation": 1, "presentation_rect": [10.0, 138.0, 130.0, 20.0], "text": "diagnostics manual" } },
      { "box": { "annotation": "Refreshes track metadata and, when in master mode, arrangement cue points/sections before re-registering the lane.", "annotation_name": "Rescan", "id": "obj-25", "maxclass": "message", "patching_rect": [160.0, 360.0, 46.0, 22.0], "presentation": 1, "presentation_rect": [148.0, 138.0, 70.0, 20.0], "text": "rescan" } },
      { "box": { "annotation": "Shows the latest sender status summary, including lane identity, counters, and diagnostic snapshots.", "annotation_name": "Last status", "id": "obj-26", "maxclass": "message", "patching_rect": [20.0, 512.0, 320.0, 22.0], "presentation": 1, "presentation_rect": [78.0, 84.0, 1012.0, 20.0], "text": "status idle" } },
      { "box": { "id": "obj-27", "maxclass": "comment", "patching_rect": [20.0, 490.0, 90.0, 20.0], "presentation": 1, "presentation_rect": [10.0, 86.0, 64.0, 18.0], "text": "Status" } },
      { "box": { "annotation": "Shows the latest debug event mirrored from this device. This is the fastest way to confirm registration, transport, or analysis activity.", "annotation_name": "Last debug", "id": "obj-28", "maxclass": "message", "patching_rect": [20.0, 584.0, 320.0, 22.0], "presentation": 1, "presentation_rect": [78.0, 110.0, 1012.0, 20.0], "text": "debug idle" } },
      { "box": { "id": "obj-29", "maxclass": "comment", "patching_rect": [20.0, 562.0, 90.0, 20.0], "presentation": 1, "presentation_rect": [10.0, 112.0, 64.0, 18.0], "text": "Debug" } },
      { "box": { "id": "obj-30", "maxclass": "newobj", "patching_rect": [360.0, 512.0, 66.0, 22.0], "text": "prepend set" } },
      { "box": { "id": "obj-31", "maxclass": "newobj", "patching_rect": [360.0, 584.0, 66.0, 22.0], "text": "prepend set" } },
      { "box": { "id": "obj-32", "maxclass": "newobj", "patching_rect": [360.0, 620.0, 92.0, 22.0], "text": "print av.device" } },
      { "box": { "annotation": "Editable lane identity. Leave it alone to follow the Ableton track name, or type a custom stable lane name for preset reconnection.", "annotation_name": "Lane name", "id": "obj-33", "maxclass": "message", "patching_rect": [20.0, 398.0, 180.0, 22.0], "presentation": 1, "presentation_rect": [86.0, 58.0, 310.0, 20.0], "text": "Lane" } },
      { "box": { "id": "obj-34", "maxclass": "newobj", "patching_rect": [212.0, 398.0, 102.0, 22.0], "text": "prepend laneName" } },
      { "box": { "id": "obj-35", "maxclass": "comment", "patching_rect": [20.0, 376.0, 90.0, 20.0], "presentation": 1, "presentation_rect": [10.0, 60.0, 72.0, 18.0], "text": "Lane name" } },
      { "box": { "annotation": "Shows the current Ableton track hosting this device. The lane name defaults to this track name until you override it.", "annotation_name": "Track", "id": "obj-36", "maxclass": "message", "patching_rect": [20.0, 456.0, 320.0, 22.0], "presentation": 1, "presentation_rect": [454.0, 58.0, 636.0, 20.0], "text": "track pending" } },
      { "box": { "id": "obj-37", "maxclass": "comment", "patching_rect": [20.0, 434.0, 60.0, 20.0], "presentation": 1, "presentation_rect": [410.0, 60.0, 40.0, 18.0], "text": "Track" } },
      { "box": { "id": "obj-38", "maxclass": "message", "patching_rect": [340.0, 142.0, 30.0, 22.0], "text": "0" } },
      { "box": { "annotation": "Off = normal lane. On = master lane. Only the master lane sends Ableton transport and section messages.", "annotation_name": "Master role", "id": "obj-39", "maxclass": "toggle", "patching_rect": [340.0, 176.0, 24.0, 24.0], "presentation": 1, "presentation_rect": [160.0, 34.0, 20.0, 20.0] } },
      { "box": { "id": "obj-40", "maxclass": "newobj", "patching_rect": [374.0, 176.0, 44.0, 22.0], "text": "sel 0 1" } },
