      { "box": { "id": "obj-6", "maxclass": "newobj", "patching_rect": [440.0, 250.0, 180.0, 22.0], "text": "udpsend 127.0.0.1 7777" } },
      { "box": { "id": "obj-10", "maxclass": "newobj", "patching_rect": [680.0, 130.0, 160.0, 22.0], "text": "udpreceive 7788" } },
