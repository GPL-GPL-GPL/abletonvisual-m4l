      { "box": { "annotation": "Shows the latest hub debug event. Fastest way to confirm relay activity.", "annotation_name": "Last debug", "id": "obj-28", "maxclass": "message", "patching_rect": [20.0, 414.0, 320.0, 22.0], "presentation": 1, "presentation_rect": [78.0, 110.0, 1012.0, 20.0], "text": "debug idle" } },
