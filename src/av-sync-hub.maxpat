      { "box": { "annotation": "Publishes a structured diagnostics snapshot.", "annotation_name": "Diagnostics", "id": "obj-24", "maxclass": "message", "patching_rect": [20.0, 288.0, 126.0, 22.0], "presentation": 1, "presentation_rect": [10.0, 62.0, 130.0, 20.0], "text": "diagnostics manual" } },
      { "box": { "annotation": "Shows the latest hub status summary, including bound ports and peer state.", "annotation_name": "Last status", "id": "obj-26", "maxclass": "message", "patching_rect": [20.0, 360.0, 320.0, 22.0], "presentation": 1, "presentation_rect": [78.0, 84.0, 1012.0, 20.0], "text": "status idle" } },
