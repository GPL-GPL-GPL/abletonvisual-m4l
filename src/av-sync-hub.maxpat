      { "box": { "id": "obj-7", "maxclass": "newobj", "patching_rect": [20.0, 108.0, 58.0, 22.0], "text": "loadbang" } },
      { "box": { "id": "obj-8", "maxclass": "message", "patching_rect": [20.0, 142.0, 30.0, 22.0], "text": "1" } },
      { "box": { "annotation": "Master relay toggle. When disabled, the hub drops lane traffic without forwarding it to the app.", "annotation_name": "Enable", "id": "obj-9", "maxclass": "toggle", "patching_rect": [20.0, 176.0, 24.0, 24.0], "presentation": 1, "presentation_rect": [10.0, 34.0, 20.0, 20.0] } },
      { "box": { "id": "obj-14", "maxclass": "message", "patching_rect": [54.0, 176.0, 64.0, 22.0], "text": "enable $1" } },
      { "box": { "id": "obj-15", "maxclass": "comment", "patching_rect": [126.0, 178.0, 60.0, 20.0], "presentation": 1, "presentation_rect": [34.0, 34.0, 46.0, 18.0], "text": "Enable" } },
      { "box": { "id": "obj-16", "maxclass": "message", "patching_rect": [20.0, 214.0, 30.0, 22.0], "text": "1" } },
      { "box": { "annotation": "Verbose hub logging. Useful while validating handshake / relay behavior.", "annotation_name": "Debug", "id": "obj-13", "maxclass": "toggle", "patching_rect": [20.0, 248.0, 24.0, 24.0], "presentation": 1, "presentation_rect": [86.0, 34.0, 20.0, 20.0] } },
      { "box": { "id": "obj-17", "maxclass": "message", "patching_rect": [54.0, 248.0, 58.0, 22.0], "text": "debug $1" } },
