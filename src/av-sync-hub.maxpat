    "boxes": [
      { "box": { "id": "obj-1", "maxclass": "comment", "patching_rect": [20.0, 18.0, 320.0, 20.0], "presentation": 1, "presentation_rect": [10.0, 8.0, 120.0, 18.0], "text": "av sync hub" } },
      { "box": { "id": "obj-2", "maxclass": "comment", "patching_rect": [20.0, 42.0, 700.0, 20.0], "presentation": 1, "presentation_rect": [140.0, 8.0, 950.0, 18.0], "text": "One per Live set. Relays lane traffic to Tauri app and owns the handshake." } },
      { "box": { "id": "obj-100", "maxclass": "newobj", "patching_rect": [900.0, 40.0, 52.0, 22.0], "text": "plugin~" } },
